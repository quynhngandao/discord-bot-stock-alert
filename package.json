    "db:studio": "drizzle-kit studio"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "pg",
        "@types/pg"
      ]
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
