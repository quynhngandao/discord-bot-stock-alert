    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test:alert": "tsx scripts/testAlert.ts",
    "test:scan": "tsx scripts/testScan.ts",
    "test:discord": "tsx scripts/testDiscord.ts",
    "db:seed": "tsx scripts/testSeedSymbols.ts",
